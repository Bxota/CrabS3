generator client {
  provider = "prisma-client"
  output   = "./app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model downloads {
  id            Int       @id @default(autoincrement())
  file_id       String?
  downloaded_at DateTime? @default(now()) @db.Timestamp(6)
  ip            String?
  user_agent    String?
  files         files?    @relation(fields: [file_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model files {
  id             String      @id
  folder_id      String?
  filename       String
  content_type   String
  size           BigInt
  uploaded_at    DateTime?   @default(now()) @db.Timestamp(6)
  expires_at     DateTime?   @db.Timestamp(6)
  storage        String?     @default("hot")
  max_downloads  Int?
  download_count Int?        @default(0)
  password_hash  String?
  email_sender   String?
  email_recipient String?
  email_message  String?
  upload_token   String?     @unique
  download_token String?     @unique
  downloads      downloads[]
  user           users?       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_id        Int?
}

model secrets {
  id             String    @id
  content        String
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  expires_at     DateTime? @db.Timestamp(6)
  max_views      Int
  view_count     Int?      @default(0)
  password_hash  String?
  user_id        Int?
  user           users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model multipart_uploads {
  file_id    String    @id
  folder_id  String?
  upload_id  String
  filename   String
  chunk_size Int
  total_size BigInt
  parts      Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model upload_tokens {
  token      String    @id
  created_at DateTime? @default(now()) @db.Timestamp(6)
  expires_at DateTime  @db.Timestamp(6)
  used       Boolean?  @default(false)
}

model invitation {
  id          String    @id @default(uuid())
  email       String    @unique
  token       String    @unique @default(uuid())
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  invitedById Int?
  invitedBy   users?    @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
}

model session {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique @default(uuid())
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  isAdmin   Boolean  @default(false)
}

model communication {
  id          Int       @id @default(autoincrement())
  type        String
  url         String
  user_id     Int?
  user        users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  active      Boolean   @default(true)
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  @@unique([user_id, type])
}

model users {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  passwordHash String
  createdAt   DateTime     @default(now())
  files       files[]
  secrets     secrets[]
  invitesSent invitation[] @relation("InvitedBy")
  sessions    session[]
  isAdmin     Boolean      @default(false)
  quota       BigInt       @default(10737418240) // 10 GB
  communications communication[]
}
